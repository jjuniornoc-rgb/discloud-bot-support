# Token do bot gerado no Discord Developer Portal
DISCORD_TOKEN=

# Client ID da aplicação no Discord Developer Portal
DISCORD_CLIENT_ID=

# IDs dos canais onde o bot vai monitorar mensagens (separados por vírgula)
# Exemplo: 123456789,987654321
ALLOWED_CHANNEL_IDS=

# IDs dos servidores (guilds) onde o bot está autorizado a operar (separados por vírgula)
# Exemplo: 111111111,222222222
ALLOWED_GUILD_IDS=

# API Key do OpenRouter (obtenha em https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Tempo de cooldown por usuário em segundos (padrão: 30)
COOLDOWN_SECONDS=30

# ID do usuário da staff para notificações de feedback negativo (opcional)
STAFF_USER_ID=

# Número máximo de mensagens no histórico de conversa por canal (padrão: 10)
MAX_HISTORY_MESSAGES=10
